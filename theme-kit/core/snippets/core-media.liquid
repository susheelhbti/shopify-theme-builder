{%- comment -%}
  CORE — responsive product media renderer
  Params:
    media: media object (required)
    sizes: sizes attribute string (optional, default 100vw)
    loading: 'lazy' | 'eager' (optional, default lazy)
  Stable hooks: [data-core-media], data-media-id
{%- endcomment -%}

{%- liquid
  assign sizes_attr = sizes | default: '100vw'
  assign loading_attr = loading | default: 'lazy'
-%}

<div class="core-media" data-core-media data-media-id="{{ media.id }}">
  {%- case media.media_type -%}
    {%- when 'image' -%}
      {{ media
        | image_url: width: 1500
        | image_tag:
          widths: '360, 540, 720, 900, 1200, 1500',
          sizes: sizes_attr,
          loading: loading_attr,
          alt: media.alt
      }}
    {%- when 'video', 'external_video' -%}
      {{ media | media_tag: controls: true, preload: 'metadata' }}
    {%- when 'model' -%}
      {{ media | media_tag }}
  {%- endcase -%}
</div>
