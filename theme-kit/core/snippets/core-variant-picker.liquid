{%- comment -%}
  CORE — variant/option picker
  Params:
    product: product object (required)
    form_id: the product form element id this picker controls (required)
  Renders one <select> per product option; core-product.js matches the
  selected option combination to a variant and updates form + price + button.
  Stable hooks:
    <core-variant-picker data-form-id>
    [data-option-select] (one per option, data-option-index)
    script[data-variant-data] (JSON: id, available, options, price, compare_at_price — prices pre-formatted server-side)
{%- endcomment -%}

{%- unless product.has_only_default_variant -%}
  <core-variant-picker class="core-variant-picker" data-form-id="{{ form_id }}">
    {%- for option in product.options_with_values -%}
      <div class="core-variant-picker__field">
        <label class="core-label" for="Option-{{ form_id }}-{{ forloop.index0 }}">
          {{ option.name }}
        </label>
        <select
          class="core-select"
          id="Option-{{ form_id }}-{{ forloop.index0 }}"
          data-option-select
          data-option-index="{{ forloop.index0 }}"
        >
          {%- for value in option.values -%}
            <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
              {{ value }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    {%- endfor -%}

    <script type="application/json" data-variant-data>
      [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id }},
            "available": {{ variant.available }},
            "options": {{ variant.options | json }},
            "price": {{ variant.price | money | json }},
            "compare_at_price": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>
  </core-variant-picker>
{%- endunless -%}
