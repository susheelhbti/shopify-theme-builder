{%- comment -%}
  CORE — product page. Layout is deliberately plain; skins restyle via tokens
  and section CSS, never by editing this file.
{%- endcomment -%}

<section class="core-main-product core-container" data-section-id="{{ section.id }}">
  <div class="core-main-product__media">
    {%- for media in product.media -%}
      {%- liquid
        if forloop.first
          assign load_mode = 'eager'
        else
          assign load_mode = 'lazy'
        endif
      -%}
      {% render 'core-media', media: media, sizes: '(min-width: 990px) 50vw, 100vw', loading: load_mode %}
    {%- endfor -%}
  </div>

  <div class="core-main-product__info">
    {%- if section.settings.show_vendor and product.vendor != blank -%}
      <p class="core-main-product__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h1 class="core-main-product__title">{{ product.title }}</h1>

    {% render 'core-price', product: product %}

    {% render 'core-product-form', product: product, section_id: section.id %}

    <div class="core-main-product__description rte">
      {{ product.description }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product page",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ]
}
{% endschema %}
