{%- comment -%} CORE — blog listing. Skins may provide card-blog; core falls back to plain links. {%- endcomment -%}

<section class="core-main-blog core-container">
  <h1 class="core-main-blog__title">{{ blog.title }}</h1>

  {%- paginate blog.articles by 12 -%}
    <div class="core-blog-grid">
      {%- for article in blog.articles -%}
        <article class="core-blog-item">
          {%- if article.image -%}
            <a href="{{ article.url }}">
              {{ article.image | image_url: width: 800 | image_tag: widths: '400, 800', sizes: '(min-width: 990px) 33vw, 100vw', loading: 'lazy', alt: article.image.alt }}
            </a>
          {%- endif -%}
          <h2 class="core-blog-item__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
          <p class="core-blog-item__meta">{{ article.published_at | date: format: 'date' }}</p>
        </article>
      {%- endfor -%}
    </div>
    {% render 'core-pagination', paginate: paginate %}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Blog",
  "class": "section-main-blog",
  "settings": []
}
{% endschema %}
